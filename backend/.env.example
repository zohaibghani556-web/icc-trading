# ─────────────────────────────────────────────────────────────────
# ICC Trading Assistant — environment variables
# ─────────────────────────────────────────────────────────────────
# INSTRUCTIONS:
#   1. Copy this file and rename the copy to just:  .env
#   2. Fill in your real values below
#   3. Never commit .env to git (it contains secrets)
# ─────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────
# Option A: local PostgreSQL (replace YOUR_USERNAME and YOUR_PASSWORD)
DATABASE_URL=postgresql+asyncpg://YOUR_USERNAME:YOUR_PASSWORD@localhost:5432/icc_trading

# Option B: Supabase (paste your connection string from the Supabase dashboard)
# DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres

# ── Security ──────────────────────────────────────────────────────
# Make these long and random — paste any random string you like
# You'll paste WEBHOOK_SECRET into TradingView's webhook header later
WEBHOOK_SECRET=icc-webhook-secret-change-this-now
JWT_SECRET=icc-jwt-secret-change-this-now

# ── Environment ────────────────────────────────────────────────────
ENVIRONMENT=development
